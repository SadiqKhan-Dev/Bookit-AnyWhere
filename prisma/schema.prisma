// ============================================================
// Booking Platform — Prisma Schema
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// ENUMS
// ============================================================

enum ListingType {
  SALON
  HOTEL
  MEDICAL
  AIRPORT
  FLIGHT
  CRUISE
  MARRIAGE_HALL
  CATERING
  MECHANIC
  PHOTOGRAPHY
  DECORATOR
  MUSICIAN
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
}

enum PaymentStatus {
  PENDING
  PAID
  REFUNDED
  FAILED
}

enum UserRole {
  CUSTOMER
  PROVIDER
  ADMIN
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum RoomType {
  SINGLE
  DOUBLE
  TWIN
  SUITE
  DELUXE
  PENTHOUSE
}

enum AppointmentType {
  IN_PERSON
  TELEMEDICINE
}

// ============================================================
// USER (synced from Clerk via webhook)
// ============================================================

model User {
  id            String   @id // Clerk user ID
  email         String   @unique
  firstName     String?
  lastName      String?
  imageUrl      String?
  role          UserRole @default(CUSTOMER)
  phone         String?
  stripeCustomerId String? @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  listings      Listing[]
  bookings      Booking[]      @relation("CustomerBookings")
  reviews       Review[]
  notifications Notification[]
  wishlists     Wishlist[]
  promoCodes    PromoCode[]

  @@map("users")
}

// ============================================================
// LISTING (Salon | Hotel | Medical | Airport | Flight | Cruise)
// ============================================================

model Listing {
  id          String      @id @default(cuid())
  type        ListingType
  title       String
  description String      @db.Text
  slug        String      @unique

  // Location
  address     String
  city        String
  state       String
  country     String      @default("US")
  zipCode     String
  latitude    Float
  longitude   Float

  // Media
  coverImage  String
  images      String[]

  // Pricing (base price in cents)
  priceFrom   Int

  // Tags (terrain / destination type — e.g. Mountain, Beach, City)
  tags        String[]

  // Meta
  isActive    Boolean  @default(true)
  isFeatured  Boolean  @default(false)
  rating      Float    @default(0)
  reviewCount Int      @default(0)

  // Provider
  providerId  String
  provider    User     @relation(fields: [providerId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  amenities       ListingAmenity[]
  services        Service[]
  rooms           Room[]
  doctors         Doctor[]
  marriageHalls   MarriageHall[]
  cateringPackages CateringPackage[]
  mechanicServices MechanicService[]
  photographyPackages PhotographyPackage[]
  decoratorPackages DecoratorPackage[]
  musicianServices MusicianService[]
  availability    AvailabilityRule[]
  bookings        Booking[]
  reviews         Review[]
  blockedDates    BlockedDate[]
  flightRoutes    FlightRoute[]
  cruiseCabins    CruiseCabin[]
  wishlists       Wishlist[]
  promoCodes      PromoCode[]

  @@index([type])
  @@index([city])
  @@index([providerId])
  @@map("listings")
}

// ============================================================
// AMENITIES
// ============================================================

model Amenity {
  id       String           @id @default(cuid())
  name     String           @unique
  icon     String
  category String

  listings ListingAmenity[]

  @@map("amenities")
}

model ListingAmenity {
  listingId String
  amenityId String

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  amenity Amenity @relation(fields: [amenityId], references: [id], onDelete: Cascade)

  @@id([listingId, amenityId])
  @@map("listing_amenities")
}

// ============================================================
// SERVICE (Salon services, Medical procedures, Airport services)
// ============================================================

model Service {
  id          String  @id @default(cuid())
  listingId   String
  name        String
  description String?
  durationMin Int     // Duration in minutes
  price       Int     // Price in cents
  category    String?
  isActive    Boolean @default(true)

  listing  Listing   @relation(fields: [listingId], references: [id], onDelete: Cascade)
  bookings Booking[]

  @@index([listingId])
  @@map("services")
}

// ============================================================
// ROOM (Hotel-specific)
// ============================================================

model Room {
  id          String   @id @default(cuid())
  listingId   String
  roomNumber  String
  type        RoomType
  name        String
  description String?
  floor       Int?
  maxGuests   Int      @default(2)
  pricePerNight Int    // in cents
  images      String[]
  amenities   String[]
  isAvailable Boolean  @default(true)

  listing  Listing   @relation(fields: [listingId], references: [id], onDelete: Cascade)
  bookings Booking[]

  @@index([listingId])
  @@map("rooms")
}

// ============================================================
// DOCTOR (Medical-specific)
// ============================================================

model Doctor {
  id             String          @id @default(cuid())
  listingId      String
  userId         String?
  name           String
  specialty      String
  qualifications String[]
  bio            String?         @db.Text
  imageUrl       String?
  consultFee     Int             // in cents
  appointmentTypes AppointmentType[]
  languages      String[]
  isAvailable    Boolean         @default(true)

  listing  Listing   @relation(fields: [listingId], references: [id], onDelete: Cascade)
  bookings Booking[]

  @@index([listingId])
  @@map("doctors")
}

// ============================================================
// FLIGHT ROUTE (Flight-specific)
// ============================================================

model FlightRoute {
  id            String @id @default(cuid())
  listingId     String
  airline       String
  flightNumber  String
  origin        String // IATA code e.g. "JFK"
  originCity    String
  destination   String // IATA code e.g. "LAX"
  destCity      String
  departureTime String // "08:30"
  arrivalTime   String // "11:45"
  durationMin   Int
  aircraft      String?

  listing Listing     @relation(fields: [listingId], references: [id], onDelete: Cascade)
  seats   FlightSeat[]

  @@index([listingId])
  @@map("flight_routes")
}

// ============================================================
// FLIGHT SEAT CLASS (Flight-specific)
// ============================================================

model FlightSeat {
  id             String @id @default(cuid())
  flightRouteId  String
  class          String // "ECONOMY", "BUSINESS", "FIRST"
  name           String // "Economy Class", "Business Class"
  pricePerSeat   Int    // in cents
  totalSeats     Int
  availableSeats Int
  amenities      String[]

  flightRoute FlightRoute @relation(fields: [flightRouteId], references: [id], onDelete: Cascade)
  bookings    Booking[]

  @@index([flightRouteId])
  @@map("flight_seats")
}

// ============================================================
// CRUISE CABIN (Cruise-specific)
// ============================================================

model CruiseCabin {
  id            String  @id @default(cuid())
  listingId     String
  type          String  // "INTERIOR", "OCEAN_VIEW", "BALCONY", "SUITE", "VILLA"
  name          String
  description   String?
  deckNumber    Int?
  maxGuests     Int     @default(2)
  pricePerNight Int     // in cents
  images        String[]
  amenities     String[]
  isAvailable   Boolean @default(true)

  listing  Listing   @relation(fields: [listingId], references: [id], onDelete: Cascade)
  bookings Booking[]

  @@index([listingId])
  @@map("cruise_cabins")
}

// ============================================================
// MARRIAGE HALL (Marriage Hall-specific)
// ============================================================

model MarriageHall {
  id            String  @id @default(cuid())
  listingId     String
  name          String
  description   String? @db.Text
  capacity      Int     // Maximum guest capacity
  pricePerDay   Int     // in cents
  images        String[]
  amenities     String[]
  isAvailable   Boolean @default(true)
  cateringIncluded Boolean @default(false)
  parkingSpaces Int?

  listing  Listing   @relation(fields: [listingId], references: [id], onDelete: Cascade)
  bookings Booking[]

  @@index([listingId])
  @@map("marriage_halls")
}

// ============================================================
// CATERING PACKAGE (Catering-specific)
// ============================================================

model CateringPackage {
  id            String  @id @default(cuid())
  listingId     String
  name          String
  description   String? @db.Text
  cuisine       String  // Type of cuisine (e.g., "Pakistani", "Chinese", "Continental")
  pricePerPerson Int    // in cents
  minGuests     Int     // Minimum guests required
  maxGuests     Int?    // Maximum capacity
  menuItems     String[] // List of dishes included
  images        String[]
  isVegetarian  Boolean @default(false)
  isHalal       Boolean @default(true)
  isAvailable   Boolean @default(true)

  listing  Listing   @relation(fields: [listingId], references: [id], onDelete: Cascade)
  bookings Booking[]

  @@index([listingId])
  @@map("catering_packages")
}

// ============================================================
// MECHANIC SERVICE (Mechanic-specific)
// ============================================================

model MechanicService {
  id            String  @id @default(cuid())
  listingId     String
  name          String
  description   String? @db.Text
  serviceType   String  // e.g., "Oil Change", "Brake Repair", "Engine Repair"
  price         Int     // in cents (can be starting price)
  durationMin   Int     // Estimated duration in minutes
  vehicleTypes  String[] // e.g., ["Car", "Bike", "Truck"]
  images        String[]
  isAvailable   Boolean @default(true)
  mobileService Boolean @default(false) // Can come to customer location

  listing  Listing   @relation(fields: [listingId], references: [id], onDelete: Cascade)
  bookings Booking[]

  @@index([listingId])
  @@map("mechanic_services")
}

// ============================================================
// PHOTOGRAPHY PACKAGE (Photography-specific)
// ============================================================

model PhotographyPackage {
  id            String  @id @default(cuid())
  listingId     String
  name          String
  description   String? @db.Text
  packageType   String  // e.g., "Wedding", "Portrait", "Event", "Product"
  price         Int     // in cents
  durationMin   Int     // Session duration in minutes
  hoursOfCoverage Int?  // For events/weddings
  numberOfPhotos Int?   // Expected number of edited photos
  includesVideo Boolean @default(false)
  images        String[] // Portfolio samples
  isAvailable   Boolean @default(true)

  listing  Listing   @relation(fields: [listingId], references: [id], onDelete: Cascade)
  bookings Booking[]

  @@index([listingId])
  @@map("photography_packages")
}

// ============================================================
// DECORATOR PACKAGE (Decorator-specific)
// ============================================================

model DecoratorPackage {
  id            String  @id @default(cuid())
  listingId     String
  name          String
  description   String? @db.Text
  packageType   String  // e.g., "Wedding", "Birthday", "Corporate"
  price         Int     // in cents
  theme         String? // e.g., "Floral", "Modern", "Traditional"
  includes      String[] // Items included (e.g., "Flowers", "Lighting", "Stage")
  images        String[]
  isAvailable   Boolean @default(true)
  setupTime     Int?    // Setup time in minutes

  listing  Listing   @relation(fields: [listingId], references: [id], onDelete: Cascade)
  bookings Booking[]

  @@index([listingId])
  @@map("decorator_packages")
}

// ============================================================
// MUSICIAN/ENTERTAINER (Musician-specific)
// ============================================================

model MusicianService {
  id            String  @id @default(cuid())
  listingId     String
  name          String
  description   String? @db.Text
  genre         String  // e.g., "Classical", "Pop", "Jazz", "Qawwali"
  price         Int     // in cents (per event/hour)
  durationMin   Int     // Performance duration in minutes
  numberOfMusicians Int @default(1)
  equipment     String[] // Equipment provided
  images        String[]
  isAvailable   Boolean @default(true)
  canTravel     Boolean @default(true)

  listing  Listing   @relation(fields: [listingId], references: [id], onDelete: Cascade)
  bookings Booking[]

  @@index([listingId])
  @@map("musician_services")
}

// ============================================================
// AVAILABILITY RULES (recurring weekly schedule)
// ============================================================

model AvailabilityRule {
  id        String    @id @default(cuid())
  listingId String
  dayOfWeek DayOfWeek
  openTime  String    // "09:00"
  closeTime String    // "18:00"
  slotDurationMin Int @default(30)
  isOpen    Boolean   @default(true)

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId])
  @@map("availability_rules")
}

// ============================================================
// BLOCKED DATES
// ============================================================

model BlockedDate {
  id        String   @id @default(cuid())
  listingId String
  date      DateTime @db.Date
  reason    String?

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId])
  @@map("blocked_dates")
}

// ============================================================
// BOOKING
// ============================================================

model Booking {
  id         String        @id @default(cuid())
  listingId  String
  customerId String
  serviceId  String?       // for salon/medical/airport
  roomId     String?       // for hotel
  doctorId   String?       // for medical
  flightSeatId  String?    // for flight
  cruiseCabinId String?    // for cruise
  marriageHallId String?   // for marriage hall
  cateringPackageId String? // for catering
  mechanicServiceId String? // for mechanic
  photographyPackageId String? // for photography
  decoratorPackageId String? // for decorator
  musicianServiceId String? // for musician

  // Time
  startDate  DateTime
  endDate    DateTime
  startTime  String?       // "10:00" for appointments
  endTime    String?

  // Guests / People
  guestCount Int           @default(1)
  guestName  String?
  guestEmail String?
  guestPhone String?
  notes      String?       @db.Text

  // Status
  status         BookingStatus @default(PENDING)
  paymentStatus  PaymentStatus @default(PENDING)

  // Pricing
  subtotal       Int           // in cents
  taxes          Int           @default(0)
  platformFee    Int           @default(0)
  discountAmount Int           @default(0)
  totalAmount    Int           // in cents
  promoCodeId    String?

  // Stripe
  stripePaymentIntentId String? @unique
  stripeSessionId       String? @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  listing     Listing     @relation(fields: [listingId], references: [id])
  customer    User        @relation("CustomerBookings", fields: [customerId], references: [id])
  service     Service?    @relation(fields: [serviceId], references: [id])
  room        Room?       @relation(fields: [roomId], references: [id])
  doctor      Doctor?     @relation(fields: [doctorId], references: [id])
  flightSeat  FlightSeat? @relation(fields: [flightSeatId], references: [id])
  cruiseCabin CruiseCabin? @relation(fields: [cruiseCabinId], references: [id])
  marriageHall MarriageHall? @relation(fields: [marriageHallId], references: [id])
  cateringPackage CateringPackage? @relation(fields: [cateringPackageId], references: [id])
  mechanicService MechanicService? @relation(fields: [mechanicServiceId], references: [id])
  photographyPackage PhotographyPackage? @relation(fields: [photographyPackageId], references: [id])
  decoratorPackage DecoratorPackage? @relation(fields: [decoratorPackageId], references: [id])
  musicianService MusicianService? @relation(fields: [musicianServiceId], references: [id])
  payment     Payment?
  review      Review?
  promoCode   PromoCode? @relation(fields: [promoCodeId], references: [id])

  @@index([listingId])
  @@index([customerId])
  @@index([startDate])
  @@map("bookings")
}

// ============================================================
// PAYMENT
// ============================================================

model Payment {
  id        String        @id @default(cuid())
  bookingId String        @unique
  amount    Int           // in cents
  currency  String        @default("usd")
  status    PaymentStatus
  stripePaymentIntentId String? @unique
  stripeChargeId        String? @unique
  refundId              String?
  refundAmount          Int?
  metadata  Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@map("payments")
}

// ============================================================
// REVIEW
// ============================================================

model Review {
  id        String  @id @default(cuid())
  listingId String
  bookingId String  @unique
  authorId  String
  rating    Int     // 1-5
  title     String?
  comment   String  @db.Text
  isVerified Boolean @default(false)
  response  String? @db.Text // provider response

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  author  User    @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([listingId])
  @@map("reviews")
}

// ============================================================
// NOTIFICATION
// ============================================================

model Notification {
  id        String  @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String  // BOOKING_CONFIRMED, BOOKING_CANCELLED, REVIEW_RECEIVED, etc.
  isRead    Boolean @default(false)
  link      String?
  metadata  Json?

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("notifications")
}

// ============================================================
// WISHLIST
// ============================================================

model Wishlist {
  id        String   @id @default(cuid())
  userId    String
  listingId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([userId, listingId])
  @@index([userId])
  @@map("wishlists")
}

// ============================================================
// PROMO CODE
// ============================================================

model PromoCode {
  id            String       @id @default(cuid())
  code          String       @unique
  description   String?
  discountType  DiscountType
  discountValue Int          // % (1-100) or fixed cents
  minOrderAmount Int?        // minimum subtotal in cents
  maxUses       Int?         // null = unlimited
  usedCount     Int          @default(0)
  expiresAt     DateTime?
  isActive      Boolean      @default(true)
  listingId     String?      // null = applies to all

  createdBy  String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  creator  User     @relation(fields: [createdBy], references: [id], onDelete: Cascade)
  listing  Listing? @relation(fields: [listingId], references: [id], onDelete: SetNull)
  bookings Booking[]

  @@index([code])
  @@index([createdBy])
  @@map("promo_codes")
}
