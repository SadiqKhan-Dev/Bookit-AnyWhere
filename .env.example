# --- UPLOADTHING ---
UPLOADTHING_SECRET=sk_live_xxxxxxxxxxxx
UPLOADTHING_APP_ID=xxxxxxxxxxxx

# --- MAPBOX ---
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=pk.eyJ1IjoieHh4eHh4IiwiYSI6Inh4eHh4eCJ9.xxxxxxxx

